{
  "manifest_version": 3,
  "name": "YTM Scheduler",
  "version": "1.0.0",
  "description": "Sleep timer & alarm scheduler for YouTube Music. Auto-stop music at bedtime, wake up with your favorite playlist.",
  "permissions": ["alarms", "storage", "tabs"],
  "host_permissions": ["https://music.youtube.com/*"],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": ["https://music.youtube.com/*"],
      "js": ["utils/constants.js", "content/content-script.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
